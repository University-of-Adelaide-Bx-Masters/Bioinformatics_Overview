##FORMAT=<ID=GT,Number=1,Type=String,Description="Genotype">
##FORMAT=<ID=DP,Number=1,Type=Integer,Description="Total Depth">
##FORMAT=<ID=VD,Number=1,Type=Integer,Description="Variant Depth">
##FORMAT=<ID=AD,Number=R,Type=Integer,Description="Allelic depths for the ref and alt alleles in the order listed">
##FORMAT=<ID=AF,Number=A,Type=Float,Description="Allele Frequency">
##FORMAT=<ID=RD,Number=2,Type=Integer,Description="Reference forward, reverse reads">
##FORMAT=<ID=ALD,Number=2,Type=Integer,Description="Variant forward, reverse reads">
##FILTER=<ID=NM3.5,Description="Set if true: INFO/TYPE != 'Complex' && INFO/NM >= 3.5 && INFO/NM < 5.25">
##bcftools_filterVersion=1.11+htslib-1.21
##bcftools_filterCommand=filter --soft-filter NM3.5 --mode + -e 'INFO/TYPE != 'Complex' && INFO/NM >= 3.5 && INFO/NM < 5.25'; Date=Thu Apr  9 11:16:39 2026
##FILTER=<ID=Q25,Description="Set if true: MQ < 25 && MQ >= 10">
##bcftools_filterCommand=filter --soft-filter Q25 --mode + -e 'MQ < 25 && MQ >= 10'; Date=Thu Apr  9 11:16:39 2026
##FILTER=<ID=LowFreqBias,Description="Set if true: INFO/AF < 0.02 && ((INFO/TYPE != 'Complex' && NM >= 2.5) || SN < 4)">
##bcftools_filterCommand=filter --soft-filter LowFreqBias --mode + -e 'INFO/AF < 0.02 && ((INFO/TYPE != 'Complex' && NM >= 2.5) || SN < 4)'; Date=Thu Apr  9 11:16:39 2026
##FILTER=<ID=LowDepthBias,Description="Set if true: (INFO/DP * INFO/AF < 6) && ((INFO/TYPE != 'Complex' && ((MQ < 55 && NM > 1) || (MQ < 60 && NM > 2))) || (INFO/DP < 10) || (QUAL < 45))">
##bcftools_filterCommand=filter --soft-filter LowDepthBias --mode + -e '(INFO/DP * INFO/AF < 6) && ((INFO/TYPE != 'Complex' && ((MQ < 55 && NM > 1) || (MQ < 60 && NM > 2))) || (INFO/DP < 10) || (QUAL < 45))'; Date=Thu Apr  9 11:16:39 2026
##FILTER=<ID=HmplymLowFreqIndel,Description="Set if true: (INFO/TYPE == 'Insertion' || INFO/TYPE == 'Deletion') && (MSILEN == 1 && MSI >=5) && INFO/AF < 0.3 && INFO/AF < (MSI*0.004)">
##bcftools_filterCommand=filter --soft-filter HmplymLowFreqIndel --mode + -e '(INFO/TYPE == 'Insertion' || INFO/TYPE == 'Deletion') && (MSILEN == 1 && MSI >=5) && INFO/AF < 0.3 && INFO/AF < (MSI*0.004)'; Date=Thu Apr  9 11:16:39 2026
##FILTER=<ID=MsiLowFreqIndel,Description="Set if true: (INFO/TYPE == 'Insertion' || INFO/TYPE == 'Deletion') && MSILEN > 1 && ABS(ILEN) == MSILEN && MSI >=5 && INFO/AF < 0.3 && INFO/AF < (MSI*0.002)">
##bcftools_filterCommand=filter --soft-filter MsiLowFreqIndel --mode + -e '(INFO/TYPE == 'Insertion' || INFO/TYPE == 'Deletion') && MSILEN > 1 && ABS(ILEN) == MSILEN && MSI >=5 && INFO/AF < 0.3 && INFO/AF < (MSI*0.002)' -O z; Date=Thu Apr  9 11:16:39 2026
